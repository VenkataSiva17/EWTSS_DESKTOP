<Page x:Class="EWTSS_DESKTOP.Presentation.Views.Dashboard.ScenarioDashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#021522"
      Title="ScenarioDashboardView">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="#03111C">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <!-- LOGO -->
                <Border Grid.Row="0"
                        BorderBrush="#1C3242"
                        BorderThickness="0,0,0,1"
                        Padding="10">
                    <Image Source="C:\Users\Admin\Downloads\white.png"
                           Width="220"
                           Height="50"
                           Stretch="Uniform"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>
                </Border>

                <!-- MENU -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,10,12,10">
                        <Button x:Name="HomeButton"
                                Content="HOME"
                                Height="36"
                                Margin="0,0,0,12"
                                Background="#169C96"
                                Foreground="White"
                                BorderBrush="{x:Null}"
                                HorizontalContentAlignment="Left"
                                Click="Home_Click"/>

                        <Button x:Name="UserManagementButton"
                                Content="USER MANAGEMENT"
                                Height="36"
                                Margin="0,0,0,10"
                                Background="Transparent"
                                Foreground="White"
                                BorderBrush="{x:Null}"
                                HorizontalContentAlignment="Left"
                                Click="UserManagement_Click"/>

                        <Button x:Name="DbManagementButton"
                                Content="DB MANAGEMENT"
                                Height="36"
                                Margin="0,0,0,10"
                                Background="Transparent"
                                Foreground="White"
                                BorderBrush="{x:Null}"
                                HorizontalContentAlignment="Left"
                                Click="DbManagement_Click"/>

                        <Button x:Name="LogManagementButton"
                                Content="LOG MANAGEMENT"
                                Height="36"
                                Margin="0,0,0,10"
                                Background="Transparent"
                                Foreground="White"
                                BorderBrush="{x:Null}"
                                HorizontalContentAlignment="Left"
                                Click="LogManagement_Click"/>

                        <Button Content="EMITTER LIBRARY"
                                Height="36"
                                Margin="0,0,0,10"
                                Background="Transparent"
                                Foreground="White"
                                BorderBrush="{x:Null}"
                                HorizontalContentAlignment="Left"/>

                        <Button Content="REPORT"
                                Height="36"
                                Margin="0,0,0,10"
                                Background="Transparent"
                                Foreground="White"
                                BorderBrush="{x:Null}"
                                HorizontalContentAlignment="Left"/>

                        <Button Content="REPLAY"
                                Height="36"
                                Margin="0,0,0,10"
                                Background="Transparent"
                                Foreground="White"
                                BorderBrush="{x:Null}"
                                HorizontalContentAlignment="Left"/>

                        <Button Content="IP CONFIGURATION"
                                Height="36"
                                Margin="0,0,0,10"
                                Background="Transparent"
                                Foreground="White"
                                BorderBrush="{x:Null}"
                                HorizontalContentAlignment="Left"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- BOTTOM BUTTON -->
                <Border Grid.Row="2" Padding="8">
                    <Button Content="+ NEW SCENARIO"
                            Height="40"
                            Margin="0,0,0,10"
                            Background="#21B3AE"
                            Foreground="Black"
                            FontWeight="Bold"
                            BorderBrush="{x:Null}"
                            Command="{Binding NewScenarioCommand}"/>
                </Border>
            </Grid>
        </Border>

        <!-- RIGHT CONTENT -->
        <Grid Grid.Column="1" Background="#021522">
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP HEADER -->
            <Grid Grid.Row="0" Background="#062235">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Scenario Generator - EWTSS"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,15,0">
                    <TextBlock Text="{Binding LoggedInUserName}"
                               Foreground="White"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <Ellipse Width="24"
                             Height="24"
                             Fill="#B9C37A"/>
                </StackPanel>
            </Grid>

            <!-- PAGE HOST -->
            <Frame x:Name="MainContentFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="#021522"/>
        </Grid>
    </Grid>
</Page>