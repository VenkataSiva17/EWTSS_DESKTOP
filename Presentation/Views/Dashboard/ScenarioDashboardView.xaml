<Page x:Class="EWTSS_DESKTOP.Presentation.Views.Dashboard.ScenarioDashboardView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#021522"
      Title="ScenarioDashboardView">

    <Page.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Margin="10,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#169C96"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder" Property="Background" Value="#169C96"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NewScenarioButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
            <Setter Property="Background" Value="#1B9C95"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border BorderBrush="#1B9C95"
                                BorderThickness="2"
                                Background="Transparent"
                                Padding="2">
                            <Border BorderBrush="Black"
                                    BorderThickness="1"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UserMenuItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="MenuItemBorder" Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="Left"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#0B2C45"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="MenuItemBorder" Property="Background" Value="#0B2C45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- LEFT SIDEBAR -->
        <Border Grid.Column="0" Background="#03111C">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="70"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>

                <!-- LOGO -->
                <Border Grid.Row="0"
                        BorderBrush="#1C3242"
                        BorderThickness="0,0,0,1"
                        Padding="10">
                    <Image Source="C:\Users\const\EWTSS_DESKTOP\Images\White.png"
                           Width="220"
                           Height="50"
                           Stretch="Uniform"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"/>
                </Border>

                <!-- MENU -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="12,10,12,10">

                        <Button x:Name="HomeButton"
                                Content="HOME"
                                Style="{StaticResource SidebarButtonStyle}"
                                Background="#169C96"
                                Click="Home_Click"/>

                        <Button x:Name="UserManagementButton"
                                Content="USER MANAGEMENT"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="UserManagement_Click"/>

                        <Button x:Name="DbManagementButton"
                                Content="DB MANAGEMENT"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="DbManagement_Click"/>

                        <Button x:Name="LogManagementButton"
                                Content="LOG MANAGEMENT"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="LogManagement_Click"/>

                        <Button x:Name="EmitterLibraryButton"
                                Content="EMITTER LIBRARY"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="EmitterLibrary_Click"/>

                        <Button x:Name="ReportButton"
                                Content="REPORT"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="Report_Click"/>

                        <Button x:Name="ReplayButton"
                                Content="REPLAY"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="Replay_Click"/>

                        <Button x:Name="IpConfigurationButton"
                                Content="IP CONFIGURATION"
                                Style="{StaticResource SidebarButtonStyle}"
                                Click="IpConfiguration_Click"/>

                        <Grid Margin="-6,10,-6,0">
                            <Button Content="+ NEW SCENARIO"
                                    Style="{StaticResource NewScenarioButtonStyle}"
                                    HorizontalAlignment="Stretch"
                                    Command="{Binding NewScenarioCommand}"/>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- RIGHT CONTENT -->
        <Grid Grid.Column="1" Background="#021522">
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- TOP HEADER -->
            <Grid Grid.Row="0" Background="#062235">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="250"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="Scenario Generator - EWTSS"
                           Foreground="White"
                           FontSize="20"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                <Grid Grid.Column="1"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center"
                      Margin="0,0,15,0">

                    <Border x:Name="UserMenuButton"
                            Width="170"
                            Height="30"
                            Background="Transparent"
                            Cursor="Hand"
                            MouseLeftButtonUp="UserMenuButton_Click">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="34"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="{Binding LoggedInUserName}"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="0,0,10,0"/>

                            <Ellipse Grid.Column="1"
                                     Width="24"
                                     Height="24"
                                     Fill="#B9C37A"
                                     VerticalAlignment="Center"
                                     HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Popup x:Name="UserDropdownPopup"
                           PlacementTarget="{Binding ElementName=UserMenuButton}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="True"
                           PopupAnimation="Fade">

                        <Border Width="190"
                                Background="#031929"
                                BorderBrush="#00D7D7"
                                BorderThickness="1"
                                CornerRadius="3">
                            <StackPanel>
                   

                                <Button Content="Change Password"
                                        Style="{StaticResource UserMenuItemStyle}"
                                        Click="ChangePassword_Click"/>

                                <Button Content="SG Config"
                                        Style="{StaticResource UserMenuItemStyle}"
                                        Click="SGConfig_Click"/>

                                <Button Content="Logout"
                                        Style="{StaticResource UserMenuItemStyle}"
                                        Click="Logout_Click"/>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>

            <!-- PAGE HOST -->
            <Frame x:Name="MainContentFrame"
                   Grid.Row="1"
                   NavigationUIVisibility="Hidden"
                   Background="#021522"/>
        </Grid>
    </Grid>
</Page>