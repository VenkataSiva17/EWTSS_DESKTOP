<Page x:Class="EWTSS_DESKTOP.Presentation.Views.Dashboard.ScenarioHomeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="clr-namespace:EWTSS_DESKTOP.Core.Models"
      Background="#021522"
      Title="ScenarioHomeView">

    <Page.Resources>
        <Style x:Key="ActionIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="#21B3AE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="EWTSS USER STATION | SCENARIOS LISTING"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,16"/>

        <!-- Search / Filter -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="460"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Height="34"
                     Background="#021522"
                     Foreground="White"
                     BorderBrush="#607080"
                     BorderThickness="1"
                     Padding="10,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Grid.Column="1"
                    Height="34"
                    Margin="2,0,0,0"
                    Content="⌕"
                    Background="#021522"
                    Foreground="White"
                    BorderBrush="#607080"
                    Command="{Binding SearchCommand}"/>

            <ComboBox Grid.Column="3"
                      Height="34"
                      Width="220"
                      Background="#021522"
                      Foreground="White"
                      BorderBrush="#607080"
                      BorderThickness="1"
                      Padding="8,0,8,0"
                      SelectedItem="{Binding SelectedStatus}"
                      ItemsSource="{Binding StatusOptions}">
                <ComboBox.Style>
                    <Style TargetType="ComboBox">
                        <Setter Property="Background" Value="#021522"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderBrush" Value="#607080"/>
                        <Setter Property="BorderThickness" Value="1"/>
                    </Style>
                </ComboBox.Style>

                <ComboBox.Resources>
                    <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#021522"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#169C96"/>
                    <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#021522"/>

                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#021522"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter Property="Background" Value="#169C96"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#169C96"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ComboBox.Resources>
            </ComboBox>
        </Grid>

        <!-- Cards -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding FilteredScenarios}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:Scenario}">
                        <Border Width="270"
                                Height="185"
                                Margin="0,0,16,16"
                                Background="#032238"
                                CornerRadius="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="48"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="10,8,10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Background="#BBC3CA"
                                            CornerRadius="2"
                                            Padding="10,3">
                                        <TextBlock Text="{Binding ScenarioStatus}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="11"/>
                                    </Border>

                                    <TextBlock Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               Foreground="#15A05D"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Text="{Binding StartDate, StringFormat={}{0:dd-MM-yyyy}}"/>
                                </Grid>

                                <StackPanel Grid.Row="1" Margin="16,8,16,0">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Text="{Binding ScenarioType}"
                                               Foreground="#16A05F"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Margin="0,6,0,18"/>

                                    <TextBlock Text="{Binding User.UserName}"
                                               Foreground="#B9C6D2"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,12,8">
                                    <Button Style="{StaticResource ActionIconButtonStyle}"
                                            ToolTip="Copy"
                                            Command="{Binding DataContext.DuplicateScenarioCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE8C8;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Button>

                                    <Button Style="{StaticResource ActionIconButtonStyle}"
                                            ToolTip="Edit"
                                            Command="{Binding DataContext.EditScenarioCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE70F;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Button>

                                    <Button Style="{StaticResource ActionIconButtonStyle}"
                                            Margin="0"
                                            ToolTip="Delete"
                                            Command="{Binding DataContext.DeleteScenarioCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE74D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>