<Page x:Class="EWTSS_DESKTOP.Presentation.Views.Dashboard.ScenarioHomeView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="clr-namespace:EWTSS_DESKTOP.Core.Models"
      Background="#021522"
      Title="ScenarioHomeView">

    <Page.Resources>
        <Style x:Key="ActionIconButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
            <Setter Property="Background" Value="#21B3AE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FlatComboBoxToggleButton" TargetType="ToggleButton">
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="Transparent"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              VerticalAlignment="Stretch"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="#607080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid SnapsToDevicePixels="True">
                            <Border x:Name="OuterBorder"
                                    Background="Transparent"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="36"/>
                                    </Grid.ColumnDefinitions>

                                    <ToggleButton Grid.Column="0"
                                                  Style="{StaticResource FlatComboBoxToggleButton}"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press">
                                        <Border Background="Transparent">
                                            <ContentPresenter Margin="10,0,0,0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          RecognizesAccessKey="True"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                          TextElement.Foreground="White"/>
                                        </Border>
                                    </ToggleButton>

                                    <Border Grid.Column="1"
                                            Background="Transparent"
                                            BorderBrush="#607080"
                                            BorderThickness="1,0,0,0">
                                        <ToggleButton Style="{StaticResource FlatComboBoxToggleButton}"
                                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                      ClickMode="Press">
                                            <TextBlock Text="▼"
                                                       Foreground="White"
                                                       FontSize="10"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </ToggleButton>
                                    </Border>

                                    <Popup x:Name="Popup"
                                           Placement="Bottom"
                                           IsOpen="{TemplateBinding IsDropDownOpen}"
                                           AllowsTransparency="True"
                                           Focusable="False"
                                           PopupAnimation="None">
                                        <Border x:Name="PopupBorder"
                                                Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                                Background="#021522"
                                                BorderBrush="#607080"
                                                BorderThickness="1">
                                            <ScrollViewer Margin="0"
                                                          SnapsToDevicePixels="True">
                                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FlatComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Background" Value="#021522"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="#021522"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#021522"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#021522"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#021522"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#021522"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="EWTSS USER STATION | SCENARIOS LISTING"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1"
                       x:Name="TimeText"
                       Foreground="White"
                       FontSize="16"
                       Margin="20,0,0,0"
                       VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="460"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     Height="34"
                     Background="#021522"
                     Foreground="White"
                     BorderBrush="#607080"
                     BorderThickness="1"
                     Padding="10,0"
                     VerticalContentAlignment="Center"
                     Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Grid.Column="1"
                    Height="34"
                    Margin="2,0,0,0"
                    Content="⌕"
                    Background="#021522"
                    Foreground="White"
                    BorderBrush="#607080"
                    Command="{Binding SearchCommand}"/>

            <ComboBox Grid.Column="3"
                      Width="220"
                      Height="38"
                      SelectedItem="{Binding SelectedStatus}"
                      ItemsSource="{Binding StatusOptions}"
                      Style="{StaticResource FlatComboBoxStyle}"
                      ItemContainerStyle="{StaticResource FlatComboBoxItemStyle}"/>
        </Grid>

        <Border Grid.Row="2"
                Width="105"
                Height="36"
                Background="#179C96"
                Cursor="Hand"
                HorizontalAlignment="Left"
                CornerRadius="2"
                Margin="0,0,0,16">
            <TextBlock Text="SCENARIOS"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="3"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding FilteredScenarios}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:Scenario}">
                        <Border Width="270"
                                Height="185"
                                Margin="0,0,16,16"
                                Background="#032238"
                                CornerRadius="2">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="34"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="48"/>
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="10,8,10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Background="#BBC3CA"
                                            CornerRadius="2"
                                            Padding="10,3">
                                        <TextBlock Text="{Binding ScenarioStatus}"
                                                   Foreground="White"
                                                   FontWeight="Bold"
                                                   FontSize="11"/>
                                    </Border>

                                    <TextBlock Grid.Column="1"
                                               HorizontalAlignment="Right"
                                               Foreground="#15A05D"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               Text="{Binding StartDate, StringFormat={}{0:dd-MM-yyyy}}"/>
                                </Grid>

                                <StackPanel Grid.Row="1" Margin="16,8,16,0">
                                    <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis"/>

                                    <TextBlock Text="{Binding ScenarioType}"
                                               Foreground="#16A05F"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Margin="0,6,0,18"/>

                                    <TextBlock Text="{Binding User.UserName}"
                                               Foreground="#B9C6D2"
                                               FontSize="14"
                                               FontWeight="SemiBold"/>
                                </StackPanel>

                                <StackPanel Grid.Row="2"
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Margin="0,0,12,8">
                                    <Button Style="{StaticResource ActionIconButtonStyle}"
                                            ToolTip="Copy"
                                            Command="{Binding DataContext.DuplicateScenarioCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE8C8;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Button>

                                    <Button Style="{StaticResource ActionIconButtonStyle}"
                                            ToolTip="Edit"
                                            Command="{Binding DataContext.EditScenarioCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE70F;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Button>

                                    <Button Style="{StaticResource ActionIconButtonStyle}"
                                            Margin="0"
                                            ToolTip="Delete"
                                            Command="{Binding DataContext.DeleteScenarioCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="&#xE74D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>