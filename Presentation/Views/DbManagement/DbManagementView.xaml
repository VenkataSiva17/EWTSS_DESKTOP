<Page x:Class="EWTSS_DESKTOP.Presentation.Views.DbManagement.DbManagementView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#021522">

    <Grid Margin="40,30,40,30">

        <!-- TITLE -->
        <TextBlock Text="DATABASE MANAGEMENT"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="Bold"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Top"/>

        <!-- MAIN CONTENT -->
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,40,0,0">

            <!-- BACKUP -->
            <Button Width="630"
                    Height="102"
                    Margin="0,0,0,62"
                    Background="#279C95"
                    BorderBrush="#0B5754"
                    BorderThickness="2"
                    Foreground="Black"
                    FontSize="28"
                    FontWeight="Bold"
                    Content="BACKUP"
                    FocusVisualStyle="{x:Null}"/>

            <!-- PURGE -->
            <Button Width="630"
                    Height="102"
                    Margin="0,0,0,62"
                    Background="#279C95"
                    BorderBrush="#0B5754"
                    BorderThickness="2"
                    Foreground="Black"
                    FontSize="28"
                    FontWeight="Bold"
                    Content="PURGE"
                    FocusVisualStyle="{x:Null}"/>

            <!-- IMPORT -->
            <Button Width="630"
                    Height="102"
                    Margin="0,0,0,62"
                    Background="#279C95"
                    BorderBrush="#0B5754"
                    BorderThickness="2"
                    Foreground="Black"
                    FontSize="28"
                    FontWeight="Bold"
                    Content="IMPORT"
                    FocusVisualStyle="{x:Null}"/>

            <!-- UPLOAD AREA -->
            <Button Width="630"
                    Height="110"
                    Background="Transparent"
                    BorderThickness="0"
                    FocusVisualStyle="{x:Null}"
                    Click="UploadButton_Click">

                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="630" Height="110">
                            <Rectangle x:Name="UploadBorder"
                                       Stroke="#D9D9D9"
                                       StrokeThickness="2"
                                       StrokeDashArray="4 3"
                                       RadiusX="8"
                                       RadiusY="8"/>

                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Click to upload"
                                           Foreground="#8D98A7"
                                           FontSize="22"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="Supported format: .sql"
                                           Foreground="#8D98A7"
                                           FontSize="13"
                                           Margin="0,8,0,0"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>
    </Grid>
</Page>