<Page x:Class="EWTSS_DESKTOP.Presentation.Views.DbManagement.DbManagementView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#021522">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="DB MANAGEMENT"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />

            <TextBlock Grid.Column="1"
                       x:Name="TimeText"
                       Foreground="White"
                       FontSize="16"
                       Margin="20,0,0,0"
                       VerticalAlignment="Center" />
        </Grid>

        <!-- MAIN CONTENT -->
        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Margin="0,40,0,0">

            <Button Width="630"
                    Height="102"
                    Margin="0,0,0,62"
                    Background="#279C95"
                    BorderBrush="#0B5754"
                    BorderThickness="2"
                    Foreground="Black"
                    FontSize="28"
                    FontWeight="Bold"
                    Content="BACKUP"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}"/>

            <Button Width="630"
                    Height="102"
                    Margin="0,0,0,62"
                    Background="#279C95"
                    BorderBrush="#0B5754"
                    BorderThickness="2"
                    Foreground="Black"
                    FontSize="28"
                    FontWeight="Bold"
                    Content="PURGE"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}"/>

            <Button Width="630"
                    Height="102"
                    Margin="0,0,0,62"
                    Background="#279C95"
                    BorderBrush="#0B5754"
                    BorderThickness="2"
                    Foreground="Black"
                    FontSize="28"
                    FontWeight="Bold"
                    Content="IMPORT"
                    Cursor="Hand"
                    FocusVisualStyle="{x:Null}"/>

            <Button Width="630"
                    Height="110"
                    Background="Transparent"
                    BorderThickness="0"
                    FocusVisualStyle="{x:Null}"
                    Cursor="Hand"
                    Click="UploadButton_Click">

                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Grid Width="630" Height="110">
                            <Rectangle x:Name="UploadBorder"
                                       Stroke="#D9D9D9"
                                       StrokeThickness="2"
                                       StrokeDashArray="4 3"
                                       RadiusX="8"
                                       RadiusY="8"/>

                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="Click to upload"
                                           Foreground="#8D98A7"
                                           FontSize="22"
                                           HorizontalAlignment="Center"/>

                                <TextBlock Text="Supported format: .sql"
                                           Foreground="#8D98A7"
                                           FontSize="13"
                                           Margin="0,8,0,0"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </ControlTemplate>
                </Button.Template>
            </Button>

        </StackPanel>
    </Grid>
</Page>