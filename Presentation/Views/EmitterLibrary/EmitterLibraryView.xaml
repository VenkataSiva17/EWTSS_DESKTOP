<Page x:Class="EWTSS_DESKTOP.Presentation.Views.EmitterLibrary.EmitterLibraryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#021522"
      Title="EmitterLibraryView">

    <Grid Margin="24,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- PAGE TITLE + CLOCK -->
        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="EMITTER LIBRARY"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1"
                       x:Name="TimeText"
                       Foreground="White"
                       FontSize="16"
                       Margin="20,0,0,0"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- SEARCH + BUTTONS -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <!-- SEARCH BOX -->
            <Grid Grid.Column="0">
                <TextBox x:Name="SearchBox"
                         Height="34"
                         Background="#0E1C2A"
                         Foreground="White"
                         BorderBrush="#607080"
                         BorderThickness="1"
                         Padding="5,0"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         TextChanged="SearchBox_TextChanged"/>

                <TextBlock x:Name="SearchPlaceholder"
                           Text="Search by Emitter Name, Type, Platform"
                           Foreground="#8D98A7"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Grid>

            <!-- SEARCH BUTTON -->
            <Button Grid.Column="1"
                    Height="34"
                    Margin="4,0,0,0"
                    Background="#0E1C2A"
                    BorderBrush="#607080"
                    BorderThickness="1"
                    Foreground="White"
                    FontSize="18"
                    Content="⌕"/>

            <!-- CREATE BUTTON -->
            <Button Grid.Column="3"
                    Height="34"
                    Background="#179C96"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    FontSize="14"
                    FontWeight="Bold"
                    Content="CREATE EMITTER"/>
        </Grid>

        <!-- TABLE -->
        <Border Grid.Row="3"
                BorderBrush="#19B1A9"
                BorderThickness="2"
                Background="Transparent">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0" Background="#1A9A92">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="SNO"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="EMITTER NAME"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <TextBlock Grid.Column="2"
                               Text="PLATFORM TYPE"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <TextBlock Grid.Column="3"
                               Text="EMITTER TYPE"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <TextBlock Grid.Column="4"
                               Text="MODE"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <TextBlock Grid.Column="5"
                               Text="ACTION"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Grid>

                <!-- EMPTY BODY -->
                <Grid Grid.Row="1"/>
            </Grid>
        </Border>
    </Grid>
</Page>