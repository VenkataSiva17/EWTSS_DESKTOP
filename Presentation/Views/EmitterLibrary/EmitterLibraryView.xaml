<Page x:Class="EWTSS_DESKTOP.Presentation.Views.EmitterLibrary.EmitterLibraryView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:sys="clr-namespace:System;assembly=mscorlib"
      Background="#021522"
      Title="EmitterLibraryView">

    <Page.Resources>
        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#03111C"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#179C96"/>
        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#03111C"/>

        <Style x:Key="PopupLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="PopupTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#03111C"/>
            <Setter Property="BorderBrush" Value="#607080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="6,0"/>
        </Style>

        <Style x:Key="PopupSmallButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="#03111C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#607080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#03111C"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#179C96"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#0F4C5C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
         <Style x:Key="NoHoverButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="#179C96"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="BorderBrush" Value="{x:Null}"/>
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Cursor" Value="Hand"/>

    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}">
                    <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#03111C"/>
            <Setter Property="BorderBrush" Value="#607080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Padding" Value="8,2,26,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"/>

                            <ContentPresenter Margin="8,0,24,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>

                            <Path Width="8"
                                  Height="5"
                                  Fill="White"
                                  Stretch="Fill"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,8,0"
                                  Data="M 0 0 L 8 0 L 4 5 Z"/>

                            <ToggleButton Background="Transparent"
                                          BorderBrush="{x:Null}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#03111C"
                                            BorderBrush="#607080"
                                            BorderThickness="1"/>
                                    <ScrollViewer Margin="1">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UnitComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DarkComboBoxStyle}">
            <Setter Property="Width" Value="56"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="8,0,20,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="2"/>

                            <ContentPresenter Margin="8,0,18,0"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Left"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>

                            <Path Width="8"
                                  Height="5"
                                  Fill="White"
                                  Stretch="Fill"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,7,0"
                                  Data="M 0 0 L 8 0 L 4 5 Z"/>

                            <ToggleButton Background="Transparent"
                                          BorderBrush="{x:Null}"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent"/>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <Popup Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Slide">
                                <Grid MinWidth="{TemplateBinding ActualWidth}"
                                      MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border Background="#03111C"
                                            BorderBrush="White"
                                            BorderThickness="1"
                                            CornerRadius="2"/>
                                    <ScrollViewer Margin="1">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="24,16,20,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="EMITTER LIBRARY"
                       Foreground="White"
                       FontSize="20"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1"
                       x:Name="TimeText"
                       Foreground="White"
                       FontSize="16"
                       Margin="20,0,0,0"
                       VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="420"/>
                <ColumnDefinition Width="48"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <TextBox x:Name="SearchBox"
                         Height="34"
                         Background="#0E1C2A"
                         Foreground="White"
                         BorderBrush="#607080"
                         BorderThickness="1"
                         Padding="8,0"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         TextChanged="SearchBox_TextChanged"/>

                <TextBlock x:Name="SearchPlaceholder"
                           Text="Search by Emitter Name, Type, Platform"
                           Foreground="#8D98A7"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Grid>

            <Button Grid.Column="1"
                    Height="34"
                    Margin="4,0,0,0"
                    Background="#0E1C2A"
                    BorderBrush="#607080"
                    BorderThickness="1"
                    Foreground="White"
                    FontSize="18"
                    Content="⌕"
                    Cursor="Hand"/>

            <Button Grid.Column="3"
                    Height="34"
                    Background="#179C96"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    Style="{StaticResource NoHoverButtonStyle}"
                    FontSize="14"
                    FontWeight="Bold"
                    Content="CREATE EMITTER"
                    Cursor="Hand"
                    Click="CreateEmitter_Click"/>
        </Grid>

        <Border Grid.Row="3"
                BorderBrush="#19B1A9"
                BorderThickness="2"
                Background="Transparent">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="220"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#1A9A92">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="250"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="120"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="SNO" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="EMITTER NAME" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="PLATFORM TYPE" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="EMITTER TYPE" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="MODE" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="5" Text="ACTION" Foreground="White" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>

                <Grid Grid.Row="1"/>
            </Grid>
        </Border>

        <Grid x:Name="CreateEmitterOverlay"
              Grid.RowSpan="5"
              Background="Transparent"
              Visibility="Collapsed"
              Panel.ZIndex="999">

            <Border Width="395"
                    Background="#021522"
                    BorderBrush="#19B1A9"
                    BorderThickness="1.5"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,2,0,0">

                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="58"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="EMITTER PROPERTIES"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="EMITTER NAME *" Style="{StaticResource PopupLabelStyle}"/>
                            <TextBox Style="{StaticResource PopupTextBoxStyle}" Margin="0,0,0,12"/>

                            <TextBlock Text="PLATFORM TYPE *" Style="{StaticResource PopupLabelStyle}"/>
                            <ComboBox Style="{StaticResource DarkComboBoxStyle}" Margin="0,0,0,12" SelectedIndex="0">
                                <sys:String>LAND STATIC</sys:String>
                                <sys:String>LAND MOBILE</sys:String>
                                <sys:String>AIR</sys:String>
                                <sys:String>SEA</sys:String>
                            </ComboBox>

                            <TextBlock Text="POSITION" Style="{StaticResource PopupLabelStyle}"/>

                            <TextBlock Text="NO. OF POINTS *" Style="{StaticResource PopupLabelStyle}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                <Button Content="-" Style="{StaticResource PopupSmallButtonStyle}"/>
                                <TextBox Text="1"
                                         Width="36"
                                         Height="28"
                                         Margin="4,0"
                                         HorizontalContentAlignment="Center"
                                         VerticalContentAlignment="Center"
                                         Background="#03111C"
                                         Foreground="White"
                                         BorderBrush="#607080"
                                         BorderThickness="1"/>
                                <Button Content="+" Style="{StaticResource PopupSmallButtonStyle}"/>
                            </StackPanel>

                            <TextBlock Text="POINT 1 *"
                                       Foreground="White"
                                       FontSize="14"
                                       FontWeight="Bold"
                                       Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="22"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="LATITUDE"
                                               Foreground="White"
                                               FontSize="13"
                                               Margin="0,0,0,4"/>
                                    <DockPanel LastChildFill="False">
                                        <TextBox Text="17° 16' 21.333&quot;"
                                                 Width="152"
                                                 Height="30"
                                                 Background="#03111C"
                                                 Foreground="White"
                                                 BorderBrush="#607080"
                                                 BorderThickness="1"
                                                 Padding="6,0"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBox Text="N"
                                                 Width="22"
                                                 Height="30"
                                                 Background="#03111C"
                                                 Foreground="White"
                                                 BorderBrush="#607080"
                                                 BorderThickness="1"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"/>
                                    </DockPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="LONGITUDE"
                                               Foreground="White"
                                               FontSize="13"
                                               Margin="0,0,0,4"/>
                                    <DockPanel LastChildFill="False">
                                        <TextBox Text="78° 29' 31.768&quot;"
                                                 Width="152"
                                                 Height="30"
                                                 Background="#03111C"
                                                 Foreground="White"
                                                 BorderBrush="#607080"
                                                 BorderThickness="1"
                                                 Padding="6,0"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBox Text="E"
                                                 Width="22"
                                                 Height="30"
                                                 Background="#03111C"
                                                 Foreground="White"
                                                 BorderBrush="#607080"
                                                 BorderThickness="1"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"/>
                                    </DockPanel>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="EMITTER TYPE *" Style="{StaticResource PopupLabelStyle}"/>
                            <ComboBox Style="{StaticResource DarkComboBoxStyle}" Margin="0,0,0,12" SelectedIndex="0">
                                <sys:String>SELECT EMITTER TYPE</sys:String>
                                <sys:String>COM</sys:String>
                                <sys:String>RADAR</sys:String>
                                <sys:String>JAMMER</sys:String>
                            </ComboBox>

                            <TextBlock Text="MODE *" Style="{StaticResource PopupLabelStyle}"/>
                            <ComboBox Style="{StaticResource DarkComboBoxStyle}" Margin="0,0,0,12" SelectedIndex="0">
                                <sys:String>FF</sys:String>
                                <sys:String>FH</sys:String>
                            </ComboBox>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="SETUP GAIN / LOSS *" Style="{StaticResource PopupLabelStyle}"/>
                                    <DockPanel LastChildFill="False">
                                        <TextBox Text="0"
                                                 Width="140"
                                                 Height="30"
                                                 Background="#03111C"
                                                 Foreground="White"
                                                 BorderBrush="#607080"
                                                 BorderThickness="1"
                                                 Padding="6,0"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBox Text="dB"
                                                 Width="32"
                                                 Height="30"
                                                 Background="#03111C"
                                                 Foreground="White"
                                                 BorderBrush="#607080"
                                                 BorderThickness="1"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"/>
                                    </DockPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="POWER TRANSMITTED *" Style="{StaticResource PopupLabelStyle}"/>
                                    <DockPanel LastChildFill="False">
                                        <TextBox Text="60"
                                                 Width="140"
                                                 Height="30"
                                                 Background="#03111C"
                                                 Foreground="White"
                                                 BorderBrush="#607080"
                                                 BorderThickness="1"
                                                 Padding="6,0"
                                                 VerticalContentAlignment="Center"/>
                                        <TextBox Text="dBm"
                                                 Width="42"
                                                 Height="30"
                                                 Background="#03111C"
                                                 Foreground="White"
                                                 BorderBrush="#607080"
                                                 BorderThickness="1"
                                                 HorizontalContentAlignment="Center"
                                                 VerticalContentAlignment="Center"/>
                                    </DockPanel>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="BANDWIDTH *" Style="{StaticResource PopupLabelStyle}"/>
                            <DockPanel LastChildFill="False" Margin="0,0,0,12">
                                <TextBox Text="30"
                                         Width="320"
                                         Height="30"
                                         Background="#03111C"
                                         Foreground="White"
                                         BorderBrush="#607080"
                                         BorderThickness="1"
                                         Padding="6,0"
                                         VerticalContentAlignment="Center"/>
                                <ComboBox Style="{StaticResource UnitComboBoxStyle}" SelectedIndex="0">
                                    <sys:String>KHz</sys:String>
                                    <sys:String>MHz</sys:String>
                                </ComboBox>
                            </DockPanel>

                            <TextBlock Text="FREQUENCY *" Style="{StaticResource PopupLabelStyle}"/>
                            <DockPanel LastChildFill="False" Margin="0,0,0,8">
                                <TextBox Height="30"
                                         Width="320"
                                         Background="#03111C"
                                         Foreground="White"
                                         BorderBrush="#607080"
                                         BorderThickness="1"
                                         Padding="6,0"
                                         VerticalContentAlignment="Center"/>
                                <ComboBox Style="{StaticResource UnitComboBoxStyle}" SelectedIndex="0">
                                    <sys:String>MHz</sys:String>
                                    <sys:String>GHz</sys:String>
                                    <sys:String>KHz</sys:String>
                                </ComboBox>
                            </DockPanel>
                        </StackPanel>
                    </ScrollViewer>

                    <Grid Grid.Row="2" Background="#062033" Margin="-8,12,-8,-8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="12"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Content="CLOSE"
                                Height="32"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                Foreground="White"
                                BorderThickness="0"
                                Style="{StaticResource NoHoverButtonStyle}"
                                FontSize="14"
                                Cursor="Hand"
                                Click="CloseCreateEmitter_Click"/>

                        <Button Grid.Column="3"
                                Content="ADD"
                                Height="32"
                                VerticalAlignment="Center"
                                Background="#179C96"
                                Foreground="White"
                                Style="{StaticResource NoHoverButtonStyle}"
                                BorderThickness="0"
                                FontSize="14"
                                FontWeight="Bold"
                                Cursor="Hand"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>