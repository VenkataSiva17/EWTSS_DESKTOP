<Page x:Class="EWTSS_DESKTOP.Presentation.Views.IpConfiguration.IpConfigurationView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#021522"
      Title="IpConfigurationView">

    <Page.Resources>

        <!-- Common TextBox -->
        <Style x:Key="DarkTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Background" Value="#021522"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#607080"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <!-- ComboBox item -->
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="#062A45"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,6"/>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="#0E3A5A"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#169C96"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ComboBox -->
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#062A45"/>
            <Setter Property="BorderBrush" Value="#062A45"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboBoxItemStyle}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Grid.Column="0"
                                                      Margin="10,0,0,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"/>

                                    <ToggleButton Grid.Column="1"
                                                  Focusable="False"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press">
                                        <TextBlock Text="▼"
                                                   Foreground="White"
                                                   FontSize="10"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </ToggleButton>
                                </Grid>
                            </Border>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="#062A45"
                                        BorderBrush="#169C96"
                                        BorderThickness="1"
                                        Width="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer>
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Buttons -->
        <Style x:Key="TealButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#179C96"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <!-- GroupBox -->
        <Style x:Key="DarkGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Foreground" Value="#13B6AE"/>
            <Setter Property="BorderBrush" Value="#13B6AE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

    </Page.Resources>

 <Grid Margin="18,14,18,14">
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="3.45*"/>
        <ColumnDefinition Width="18"/>
        <ColumnDefinition Width="1.35*"/>
    </Grid.ColumnDefinitions>

    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- PAGE TITLE -->
    <Grid Grid.Row="0"
          Grid.ColumnSpan="3"
          HorizontalAlignment="Stretch"
          Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0"
                   Text="IP CONFIGURATION"
                   Foreground="White"
                   FontSize="22"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Left"/>

        <TextBlock Grid.Column="1"
                   x:Name="TimeText"
                   Foreground="White"
                   FontSize="16"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"/>
   
</Grid>

        <!-- LEFT PANEL -->
        <GroupBox Grid.Row="1"
                  Grid.Column="0"
                  Header="DRS CONFIGURATION"
                  Style="{StaticResource DarkGroupBoxStyle}"
                  Margin="0,0,10,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Active Scenario -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="195"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,10,0">
                        <TextBlock Text="Active Scenario Name :"
                                   Foreground="White"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   Margin="0,0,10,0"/>
                        <TextBox Text="scenario_demo_copy1"
                                 Width="185"
                                 Style="{StaticResource DarkTextBoxStyle}"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="Check Active Scenario"
                            Width="185"
                            Style="{StaticResource TealButtonStyle}"/>
                </Grid>

                <!-- DRS1 -->
                <GroupBox Grid.Row="1"
                          Header="DRS1"
                          Style="{StaticResource DarkGroupBoxStyle}"
                          Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="155"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="145"/>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="145"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="DRS1"
                                 Style="{StaticResource DarkTextBoxStyle}"/>

                        <TextBlock Grid.Column="1"
                                   Text="RDFS:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>

                        <ComboBox Grid.Column="2"
                                  Style="{StaticResource DarkComboBoxStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Select RDFS"/>
                            <ComboBoxItem Content="CC1_RDFS1"/>
                        </ComboBox>

                        <TextBlock Grid.Column="3"
                                   Text="JSVUSHF:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>

                        <ComboBox Grid.Column="4"
                                  Style="{StaticResource DarkComboBoxStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Select JSVUSHF"/>
                            <ComboBoxItem Content="CC1_JSVUSHF1"/>
                        </ComboBox>

                        <TextBlock Grid.Column="5"
                                   Text="IP:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>

                        <TextBox Grid.Column="6"
                                 Text="192.168.1.152"
                                 Style="{StaticResource DarkTextBoxStyle}"/>

                        <TextBlock Grid.Column="7"
                                   Text="PORT:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>

                        <TextBox Grid.Column="8"
                                 Text="9092"
                                 Style="{StaticResource DarkTextBoxStyle}"/>

                        <Ellipse Grid.Column="9"
                                 Width="18"
                                 Height="18"
                                 Fill="#2ED573"
                                 VerticalAlignment="Center"
                                 Margin="14,0,0,0"/>

                        <Button Grid.Column="10"
                                Content="Verify"
                                Width="72"
                                Margin="12,0,0,0"
                                Style="{StaticResource TealButtonStyle}"/>
                    </Grid>
                </GroupBox>

                <!-- DRS2 -->
                <GroupBox Grid.Row="2"
                          Header="DRS2"
                          Style="{StaticResource DarkGroupBoxStyle}"
                          Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="155"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="145"/>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="145"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="DRS2"
                                 Style="{StaticResource DarkTextBoxStyle}"/>

                        <TextBlock Grid.Column="1"
                                   Text="RDFS:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>

                        <ComboBox Grid.Column="2"
                                  Style="{StaticResource DarkComboBoxStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Select RDFS"/>
                            <ComboBoxItem Content="CC1_RDFS"/>
                        </ComboBox>

                        <TextBlock Grid.Column="3"
                                   Text="JSVUSHF:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>

                        <ComboBox Grid.Column="4"
                                  Style="{StaticResource DarkComboBoxStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Select JSVUSHF"/>
                            <ComboBoxItem Content="CC1_JSVUSHF"/>
                        </ComboBox>

                        <TextBlock Grid.Column="5"
                                   Text="IP:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>

                        <TextBox Grid.Column="6"
                                 Text="0.0.0.0"
                                 Style="{StaticResource DarkTextBoxStyle}"/>

                        <TextBlock Grid.Column="7"
                                   Text="PORT:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>

                        <TextBox Grid.Column="8"
                                 Text="9092"
                                 Style="{StaticResource DarkTextBoxStyle}"/>

                        <Ellipse Grid.Column="9"
                                 Width="18"
                                 Height="18"
                                 Fill="#FF4D4D"
                                 VerticalAlignment="Center"
                                 Margin="14,0,0,0"/>

                        <Button Grid.Column="10"
                                Content="Verify"
                                Width="72"
                                Margin="12,0,0,0"
                                Style="{StaticResource TealButtonStyle}"/>
                    </Grid>
                </GroupBox>

                <!-- DRS3 -->
                <GroupBox Grid.Row="3"
                          Header="DRS3"
                          Style="{StaticResource DarkGroupBoxStyle}"
                          Margin="0,0,0,22">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="155"/>
                            <ColumnDefinition Width="55"/>
                            <ColumnDefinition Width="145"/>
                            <ColumnDefinition Width="75"/>
                            <ColumnDefinition Width="145"/>
                            <ColumnDefinition Width="40"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Text="DRS3"
                                 Style="{StaticResource DarkTextBoxStyle}"/>

                        <TextBlock Grid.Column="1"
                                   Text="RDFS:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>

                        <ComboBox Grid.Column="2"
                                  Style="{StaticResource DarkComboBoxStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Select RDFS"/>
                            <ComboBoxItem Content="CC1_RDFS"/>
                        </ComboBox>

                        <TextBlock Grid.Column="3"
                                   Text="JSVUSHF:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>

                        <ComboBox Grid.Column="4"
                                  Style="{StaticResource DarkComboBoxStyle}"
                                  SelectedIndex="0">
                            <ComboBoxItem Content="Select JSVUSHF"/>
                            <ComboBoxItem Content="CC1_JSVUSHF"/>
                        </ComboBox>

                        <TextBlock Grid.Column="5"
                                   Text="IP:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>

                        <TextBox Grid.Column="6"
                                 Text="0.0.0.0"
                                 Style="{StaticResource DarkTextBoxStyle}"/>

                        <TextBlock Grid.Column="7"
                                   Text="PORT:"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"/>

                        <TextBox Grid.Column="8"
                                 Text="9092"
                                 Style="{StaticResource DarkTextBoxStyle}"/>

                        <Ellipse Grid.Column="9"
                                 Width="18"
                                 Height="18"
                                 Fill="#FF4D4D"
                                 VerticalAlignment="Center"
                                 Margin="14,0,0,0"/>

                        <Button Grid.Column="10"
                                Content="Verify"
                                Width="72"
                                Margin="12,0,0,0"
                                Style="{StaticResource TealButtonStyle}"/>
                    </Grid>
                </GroupBox>

                <!-- Bottom buttons -->
                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,6,0,0">
                    <Button Content="VERIFY ALL"
                            Width="122"
                            Margin="0,0,16,0"
                            Style="{StaticResource TealButtonStyle}"/>

                    <Button Content="SAVE CONFIGURATION"
                            Width="178"
                            Style="{StaticResource TealButtonStyle}"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- RIGHT PANEL -->
        <GroupBox Grid.Row="1"
                  Grid.Column="2"
                  Header="IP TABLE"
                  Style="{StaticResource DarkGroupBoxStyle}">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="48"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Background="#179C96">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="115"/>
                        <ColumnDefinition Width="165"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               Text="SNO"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <TextBlock Grid.Column="1"
                               Text="ENTITY NAME"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <TextBlock Grid.Column="2"
                               Text="IP ADDRESS:PORT"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>

                    <TextBlock Grid.Column="3"
                               Text="STATUS"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                </Grid>

                <!-- Row 1 -->
                <Grid Grid.Row="1" Background="#021522">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="115"/>
                        <ColumnDefinition Width="165"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="1" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="DRS1" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="192.168.1.152:9092" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="VERIFIED" Foreground="#39FF88" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>

                <!-- Row 2 -->
                <Grid Grid.Row="2" Background="#04243B">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="115"/>
                        <ColumnDefinition Width="165"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="2" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="DRS2" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="0.0.0.0:9092" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="NOT VERIFIED" Foreground="#FFC52E" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>

                <!-- Row 3 -->
                <Grid Grid.Row="3" Background="#021522">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="55"/>
                        <ColumnDefinition Width="115"/>
                        <ColumnDefinition Width="165"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="3" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="DRS3" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="0.0.0.0:9092" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="NOT VERIFIED" Foreground="#FFC52E" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Grid>
            </Grid>
        </GroupBox>
    </Grid>
</Page>