<Page x:Class="EWTSS_DESKTOP.Presentation.Views.LogManagement.LogManagementView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#021522"
      Title="LogManagementView">

    <Page.Resources>
        <Style x:Key="TopTabButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderBrush" Value="White"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#179C96"/>
            <Setter Property="Foreground" Value="Black"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#27B7AE"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>

                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1F9F98"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    <Style x:Key="NoHoverButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="#179C96"/>
    <Setter Property="Foreground" Value="White"/>
    <Setter Property="BorderBrush" Value="{x:Null}"/>
    <Setter Property="FontSize" Value="14"/>
    <Setter Property="FontWeight" Value="Bold"/>
    <Setter Property="Cursor" Value="Hand"/>

    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}">
                    <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter.Value>
    </Setter>
</Style>
    </Page.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="LOG MANAGEMENT"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1"
                       x:Name="TimeText"
                       Foreground="White"
                       FontSize="16"
                       Margin="20,0,0,0"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- TOP TABS -->
        <Grid Grid.Row="1" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="UserTab"
                    Grid.Column="0"
                    Content="USER"
                    Style="{StaticResource TopTabButtonStyle}"
                    Background="#27B7AE"
                    Foreground="White"
                    FontWeight="Bold"
                    
                    Click="UserTab_Click"/>

            <Button x:Name="SentToDrsTab"
                    Grid.Column="1"
                    Content="SENT TO DRS"
                    Style="{StaticResource TopTabButtonStyle}"
                    Background="#179C96"
                    Foreground="Black"
                    Click="SentToDrsTab_Click"/>

            <Button x:Name="ReceivedFromDrsTab"
                    Grid.Column="2"
                    Content="RECEIVED FROM DRS"
                    Style="{StaticResource TopTabButtonStyle}"
                    Background="#179C96"
                    Foreground="Black"
                    Click="ReceivedFromDrsTab_Click"/>

            <Button x:Name="SystemTab"
                    Grid.Column="3"
                    Content="SYSTEM"
                    Style="{StaticResource TopTabButtonStyle}"
                    Background="#179C96"
                    Foreground="Black"
                    Click="SystemTab_Click"/>
        </Grid>

        <!-- SEARCH + REFRESH -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="500"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- SEARCH BOX WITH PLACEHOLDER -->
            <Grid Grid.Column="0">
                <TextBox x:Name="SearchBox"
                         Height="34"
                         Background="#0E1C2A"
                         Foreground="White"
                         BorderBrush="#607080"
                         BorderThickness="1"
                         Padding="5,0"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         TextChanged="SearchBox_TextChanged"/>

                <TextBlock x:Name="SearchPlaceholder"
                           Text="Search by Date, Log Type, Module Function"
                           Foreground="#8D98A7"
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Grid>

            <!-- SEARCH BUTTON -->
            <Button Grid.Column="1"
                    Height="34"
                    Background="#0E1C2A"
                    BorderBrush="#607080"
                    Foreground="White"
                    FontSize="18"
                    Content="⌕"/>

            <!-- REFRESH BUTTON -->
            <Button Grid.Column="3"
                    Height="34"
                    Background="#179C96"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    Style="{StaticResource NoHoverButtonStyle}"
                    FontSize="14"
                    FontWeight="Bold"
                    Cursor="Hand"
                
                    Content="REFRESH LOG DATA"/>
        </Grid>

        <!-- TABLE HEADER -->
        <Grid Grid.Row="3" Background="#179C96" Height="40" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="SNO"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1"
                       Text="DATE"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="2"
                       Text="LOG TYPE"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="3"
                       Text="MODULE"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="4"
                       Text="FUNCTION"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="5"
                       Text="MESSAGE"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

    </Grid>
</Page>