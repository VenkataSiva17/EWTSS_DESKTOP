<Page x:Class="EWTSS_DESKTOP.Presentation.Views.LogManagement.LogManagementView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#021522"
      Title="LogManagementView">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="70"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TITLE -->
        <TextBlock Text="LOG MANAGEMENT"
                   Foreground="White"
                   FontSize="16"
                   FontWeight="Bold"
                   Margin="0,10,0,20"/>

        <!-- TOP TABS -->
        <Grid Grid.Row="1" Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#257874" BorderBrush="White" BorderThickness="1">
                <TextBlock Text="USER"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <Border Grid.Column="1" Background="#179C96" BorderBrush="White" BorderThickness="1">
                <TextBlock Text="SENT TO DRS"
                           Foreground="Black"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <Border Grid.Column="2" Background="#179C96" BorderBrush="White" BorderThickness="1">
                <TextBlock Text="RECEIVED FROM DRS"
                           Foreground="Black"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <Border Grid.Column="3" Background="#179C96" BorderBrush="White" BorderThickness="1">
                <TextBlock Text="SYSTEM"
                           Foreground="Black"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- SEARCH + REFRESH -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="500"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- SEARCH BOX WITH PLACEHOLDER -->
            <Grid Grid.Column="0">
                <TextBox x:Name="SearchBox"
                         Height="48"
                         Background="#0E1C2A"
                         Foreground="White"
                         BorderBrush="#607080"
                         BorderThickness="1"
                         Padding="20,0"
                         VerticalContentAlignment="Center"
                         FontSize="14"
                         TextChanged="SearchBox_TextChanged"/>

                <TextBlock x:Name="SearchPlaceholder"
                           Text="Search by Date, Log Type, Module Function"
                           Foreground="#8D98A7"
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"
                           IsHitTestVisible="False"/>
            </Grid>

            <!-- SEARCH BUTTON -->
            <Button Grid.Column="1"
                    Height="48"
                    Background="#0E1C2A"
                    BorderBrush="#607080"
                    Foreground="White"
                    FontSize="18"
                    Content="⌕"/>

            <!-- REFRESH BUTTON -->
            <Button Grid.Column="3"
                    Height="48"
                    Background="#179C96"
                    Foreground="White"
                    BorderBrush="{x:Null}"
                    FontSize="14"
                    FontWeight="Bold"
                    Content="REFRESH LOG DATA"/>
        </Grid>

        <!-- TABLE HEADER -->
        <Grid Grid.Row="3" Background="#179C96" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="SNO"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="1"
                       Text="DATE"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="2"
                       Text="LOG TYPE"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="3"
                       Text="MODULE"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="4"
                       Text="FUNCTION"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <TextBlock Grid.Column="5"
                       Text="MESSAGE"
                       Foreground="White"
                       FontWeight="Bold"
                       FontSize="14"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- BODY -->
        
    </Grid>
</Page>