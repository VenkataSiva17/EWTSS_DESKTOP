<Page x:Class="EWTSS_DESKTOP.Presentation.Views.Login.LoginView"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#031929"
      Title="LoginView">

    <Page.Resources>

        <Style x:Key="InputLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D6E2EA"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#08263B"/>
            <Setter Property="BorderBrush" Value="#4E6A7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,36,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="InputPasswordBoxStyle" TargetType="PasswordBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#08263B"/>
            <Setter Property="BorderBrush" Value="#4E6A7A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,0,36,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EyeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AFC3CF"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LoginButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="#179C96"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="BtnBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="BtnBorder"
                                        Property="Background"
                                        Value="#21B3AE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="BtnBorder"
                                        Property="Background"
                                        Value="#14837E"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="BtnBorder"
                                        Property="Opacity"
                                        Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ForgotPasswordTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#AFC3CF"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,14,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top title -->
        <Grid Grid.Row="0" Margin="30,0,30,0">
            <TextBlock Text="ELECTRONIC WARFARE TRAINING SIMULATOR SYSTEM"
                       Foreground="White"
                       FontSize="22"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="40,20,40,40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left side -->
            <Grid Grid.Column="0">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Image Source="C:\Users\const\EWTSS_DESKTOP\Images\White.png"
                           Width="340"
                           Height="140"
                           Stretch="Uniform"/>
                </StackPanel>
            </Grid>

            <!-- Divider -->
            <Border Grid.Column="1"
                    Background="#4E6A7A"
                    Margin="0,40"/>

            <!-- Right side -->
            <Grid Grid.Column="2">
                <Border Width="360"
                        Padding="28"
                        Background="#041C2C"
                        BorderBrush="#12364A"
                        BorderThickness="1"
                        CornerRadius="8"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <StackPanel>

                        <TextBlock Text="HELLO!"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Login to your account to continue"
                                   FontSize="13"
                                   Foreground="#AFC3CF"
                                   Margin="0,6,0,24"/>

                        <!-- Username -->
                        <TextBlock Text="Username"
                                   Style="{StaticResource InputLabelStyle}"/>

                        <TextBox Height="38"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Password -->
                        <TextBlock Text="Password"
                                   Style="{StaticResource InputLabelStyle}"/>

                        <Grid Margin="0,0,0,18">
                            <PasswordBox x:Name="PasswordBox"
                                         Style="{StaticResource InputPasswordBoxStyle}"
                                         PasswordChanged="PasswordBox_PasswordChanged"/>

                            <TextBox x:Name="TextBoxVisible"
                                     Style="{StaticResource InputTextBoxStyle}"
                                     Visibility="Collapsed"
                                     TextChanged="TextBoxVisible_TextChanged"
                                     Margin="0"/>

                            <Button x:Name="BtnTogglePassword"
                                    Style="{StaticResource EyeButtonStyle}"
                                    Content="&#xE722;"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,6,0"
                                    Click="BtnTogglePassword_Click"/>
                        </Grid>

                        <!-- Login -->
                        <Button Content="LOGIN"
                                Style="{StaticResource LoginButtonStyle}"
                                Command="{Binding LoginCommand}"/>

                        <TextBlock Text="Forgot Password?"
                                   Style="{StaticResource ForgotPasswordTextStyle}"/>

                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>