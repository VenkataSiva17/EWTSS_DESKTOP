<Window x:Class="EWTSS_DESKTOP.Presentation.Views.Scenario.CreateScenarioWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Scenario"
        Width="680"
        Height="300"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False">

    <Border Background="#032238"
            BorderBrush="#607080"
            BorderThickness="1"
            CornerRadius="2"
            Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0"
                       Text="CREATE SCENARIO"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Name -->
            <TextBlock Grid.Row="1"
                       Text="NAME *"
                       Foreground="White"
                       FontSize="12"
                       FontWeight="Bold"
                       Margin="0,0,0,6"/>

            <TextBox x:Name="TxtName"
                     Grid.Row="2"
                     Height="34"
                     Background="#021522"
                     Foreground="White"
                     BorderBrush="#607080"
                     BorderThickness="1"
                     VerticalContentAlignment="Center"
                     Padding="10,0"
                     Margin="0,0,0,15"/>

            <!-- Description -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="DESCRIPTION"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="Bold"
                           Margin="0,0,0,6"/>

                <TextBox x:Name="TxtDescription"
                         Grid.Row="1"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         MaxLength="256"
                         Height="95"
                         Background="#021522"
                         Foreground="White"
                         BorderBrush="#607080"
                         BorderThickness="1"
                         Padding="10"
                         TextChanged="TxtDescription_TextChanged"/>

                <TextBlock x:Name="TxtRemaining"
                           Grid.Row="2"
                           Text="256 characters remaining"
                           Foreground="#B9C6D2"
                           FontSize="11"
                           HorizontalAlignment="Right"
                           Margin="0,6,0,0"/>
            </Grid>

            <!-- Buttons -->
            <StackPanel Grid.Row="4"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,20,0,0">
                <Button Content="CANCEL"
                        Width="90"
                        Height="34"
                        Margin="0,0,10,0"
                        Background="Transparent"
                        Foreground="White"
                        BorderBrush="{x:Null}"
                        Click="Cancel_Click"/>

                <Button Content="CREATE"
                        Width="90"
                        Height="34"
                        Background="#7E8EA1"
                        Foreground="White"
                        BorderBrush="{x:Null}"
                        Click="Create_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>