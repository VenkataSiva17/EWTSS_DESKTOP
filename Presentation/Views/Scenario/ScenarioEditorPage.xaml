<Page x:Class="EWTSS_DESKTOP.Presentation.Views.Scenario.ScenarioEditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:wf="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
      Background="#021522"
      Title="ScenarioEditorPage">

    <Page.Resources>
        <Style x:Key="NoHoverButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#179C96"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#062235"/>
            <Setter Property="BorderBrush" Value="#5A7388"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Height" Value="34"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="34"/>
                                </Grid.ColumnDefinitions>

                                <!-- selected item text -->
                                <ContentPresenter Grid.Column="0"
                                          Margin="10,0,6,0"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          RecognizesAccessKey="True"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>

                                <!-- arrow area -->
                                <Border Grid.Column="1"
                                Background="#062235"
                                BorderBrush="#5A7388"
                                BorderThickness="1,0,0,0">
                                    <Path Width="10"
                                  Height="6"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Fill="White"
                                  Data="M 0 0 L 5 5 L 10 0 Z"/>
                                </Border>

                                <ToggleButton Grid.ColumnSpan="2"
              Background="Transparent"
              BorderBrush="Transparent"
              BorderThickness="0"
              Focusable="False"
              ClickMode="Press"
              OverridesDefaultStyle="True"
              FocusVisualStyle="{x:Null}"
              IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Grid>

                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           PopupAnimation="Slide"
                           Focusable="False">
                                <Border Background="#031929"
                                BorderBrush="#00D7D7"
                                BorderThickness="1"
                                MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="220">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DarkComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#031929"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="4,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <!-- no hover background -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#031929"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="TopButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Background" Value="#21B3AE"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FlatTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#021522"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#21B3AE"/>
                    <Setter Property="Background" Value="#021522"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="NewScenarioButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
            <Setter Property="Background" Value="#1B9C95"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border BorderBrush="#1B9C95"
                                BorderThickness="2"
                                Background="Transparent"
                                Padding="2">
                            <Border BorderBrush="Black"
                                    BorderThickness="1"
                                    Background="{TemplateBinding Background}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#021522"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#5A7388"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="MiniMapButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#21B3AE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#021522"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <Style x:Key="GridCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#032238"/>
            <Setter Property="BorderBrush" Value="#11364B"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <Style x:Key="GridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#032238"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0A3047"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0A3047"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="BottomActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP HEADER -->
        <Grid Grid.Row="0" Background="#041B2B">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="4,0,0,0">
                <Button Width="28"
                        Height="28"
                        Margin="0,0,8,0"
                        Background="Transparent"
                        Foreground="White"
                        BorderBrush="#5A7388"
                        Click="Back_Click">
                    <TextBlock Text="←"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Image Source="/Images/white.png"
                       Width="190"
                       Height="36"
                       Stretch="Uniform"
                       VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Column="1"
                       Text="Scenario Generator - EWTSS"
                       Foreground="White"
                       FontSize="17"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0">
                <TextBlock x:Name="UserNameTextBlock"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <Ellipse Width="22"
                         Height="22"
                         Fill="#B9C37A"
                         VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- SECOND BAR -->
        <Grid Grid.Row="1" Background="#021522">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       x:Name="ScenarioTitleTextBlock"
                       Foreground="#21B3AE"
                       FontSize="13"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="70,0,0,0"/>

            <TextBlock Grid.Column="1"
                       Text="CONFIGURATION"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                <Button Content="EXECUTE" Style="{StaticResource TopButtonStyle}"/>
                <Button Content="START" Style="{StaticResource TopButtonStyle}"/>
                <Button Content="START RECORDING"
                        Style="{StaticResource TopButtonStyle}"
                        MinWidth="120"/>
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT TREE -->
            <Border Grid.Column="0"
                    Background="#021522"
                    BorderBrush="#30495C"
                    BorderThickness="0,1,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="44"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="SCENARIO"
                                   Foreground="#21B3AE"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Margin="12,12,0,8"/>

                        <TreeView x:Name="ScenarioTree"
                                  Margin="8,0,8,8"
                                  Background="#021522"
                                  Foreground="White"
                                  BorderBrush="{x:Null}"
                                  ItemContainerStyle="{StaticResource FlatTreeItemStyle}"
                                  SelectedItemChanged="ScenarioTree_SelectedItemChanged"/>
                    </StackPanel>

                    <Button Grid.Row="1"
                            Content="DRS DATA TABLE"
                            Width="120"
                            Height="30"
                            HorizontalAlignment="Left"
                            Margin="12,0,0,8"
                            Background="#21B3AE"
                            Foreground="White"
                            Style="{StaticResource NoHoverButtonStyle}"
                            BorderBrush="{x:Null}"
                            FontWeight="Bold"/>
                </Grid>
            </Border>
            
            
            
            
            
            
            
            
            
            
            
            

            <!-- MIDDLE DETAILS -->
            <Grid Grid.Column="1" Background="#021522">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="230"/>
                </Grid.RowDefinitions>

                
                
                
                <!-- SCENARIO DETAILS PANEL -->
                <Border x:Name="ScenarioDetailsBorder"
                        Grid.Row="0"
                        Background="#032238"
                        BorderBrush="#30495C"
                        BorderThickness="0,1,1,1"
                        Margin="0,0,0,10"
                        Visibility="Visible">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="SCENARIO DETAILS"
                                   Style="{StaticResource PanelTitleStyle}"
                                   Margin="0,0,0,14"/>

                        <TextBlock Grid.Row="1"
                                   Text="SCENARIO NAME *"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,6"/>

                        <TextBox Grid.Row="2"
                                 x:Name="ScenarioNameTextBox"
                                 Style="{StaticResource EditorTextBoxStyle}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Grid.Row="3"
                                   Text="DESCRIPTION"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,6"/>

                        <Grid Grid.Row="4" Margin="0,0,0,14">
                            <TextBox x:Name="ScenarioDescriptionTextBox"
                                     Height="78"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#021522"
                                     Foreground="White"
                                     BorderBrush="#5A7388"
                                     BorderThickness="1"
                                     Padding="8"/>
                            <TextBlock x:Name="DescriptionCountTextBlock"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Margin="0,0,8,6"
                                       Foreground="#C9D4DD"
                                       FontSize="10"/>
                        </Grid>

                        <TextBlock Grid.Row="5"
                                   Text="SCENARIO SETTINGS"
                                   Style="{StaticResource PanelTitleStyle}"
                                   Margin="0,0,0,12"/>

                        <StackPanel Grid.Row="6" Margin="0,0,0,8">
                            <TextBlock x:Name="ScenarioCreatedDateTextBlock"
                                       Foreground="White"
                                       FontSize="12"
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="ScenarioCreatedTimeTextBlock"
                                       Foreground="White"
                                       FontSize="12"/>
                        </StackPanel>

                        <TextBlock Grid.Row="7"
                                   Text="SCENARIO DURATION (HH:MM:SS) *"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,6"/>

                        <Grid Grid.Row="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0"
                                     x:Name="ScenarioDurationTextBox"
                                     Style="{StaticResource EditorTextBoxStyle}"/>

                            <TextBlock Grid.Row="2"
                                       Text="EXECUTION TIME (HH:MM:SS)"
                                       Style="{StaticResource LabelStyle}"
                                       Margin="0,0,0,6"/>

                            <TextBox Grid.Row="3"
                                     x:Name="ScenarioExecutionTimeTextBox"
                                     Style="{StaticResource EditorTextBoxStyle}"/>
                        </Grid>

                        <Button Grid.Row="9"
                                Content="UPDATE"
                                HorizontalAlignment="Right"
                                Width="90"
                                Background="Transparent"
                                Foreground="#21B3AE"
                                Style="{StaticResource NoHoverButtonStyle}"
                                BorderBrush="{x:Null}"
                                FontWeight="Bold"
                                Click="CreateScenario_Click"/>
                    </Grid>
                </Border>















                <!-- JSVUSHF PROPERTIES PANEL -->
                <Border x:Name="JsvushfPropertiesBorder"
        Grid.Row="0"
        Background="#032238"
        BorderBrush="#30495C"
        BorderThickness="0,1,1,1"
        Margin="0,0,0,10"
        Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="48"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#032238">
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="20"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="20"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="20"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- TITLE -->
                                <TextBlock x:Name="JsvushfTitleTextBlock"
                           Grid.Row="0"
                           Text="JSVUSHF1 PROPERTIES"
                           Foreground="White"
                           FontSize="15"
                           FontWeight="Bold"
                           Margin="0,0,0,18"/>

                                <!-- NAME -->
                                <TextBlock Grid.Row="1"
                           Text="JSVUSHF NAME *"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="Bold"
                           Margin="0,0,0,6"/>

                                <TextBox x:Name="JsvushfNameTextBox"
                         Grid.Row="2"
                         Text="JSVUSHF1"
                         Style="{StaticResource EditorTextBoxStyle}"
                         Margin="0,0,0,18"/>

                                <!-- POSITION -->
                                <TextBlock Grid.Row="3"
                           Text="POSITION"
                           Foreground="White"
                           FontSize="13"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                                <Grid Grid.Row="4" Margin="0,0,0,20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="LATITUDE *"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox x:Name="JsvushfLatitudeTextBox"
                                     Text="21° 24' 54.318''"
                                     Style="{StaticResource EditorTextBoxStyle}"/>

                                            <TextBox Grid.Column="1"
                                     x:Name="JsvushfLatitudeDirectionTextBox"
                                     Text="N"
                                     Margin="4,0,0,0"
                                     Style="{StaticResource EditorTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="LONGITUDE *"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="30"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox x:Name="JsvushfLongitudeTextBox"
                                     Text="77° 36' 49.554''"
                                     Style="{StaticResource EditorTextBoxStyle}"/>

                                            <TextBox Grid.Column="1"
                                     x:Name="JsvushfLongitudeDirectionTextBox"
                                     Text="E"
                                     Margin="4,0,0,0"
                                     Style="{StaticResource EditorTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <!-- FREQUENCY RANGE -->
                                <TextBlock Grid.Row="5"
                           Text="FREQUENCY RANGE * (30 MHz - 6000 MHz)"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="Bold"
                           Margin="0,0,0,10"/>

                                <Grid Grid.Row="6" Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="MIN"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox x:Name="JsvushfMinFreqTextBox"
                                     Text="435"
                                     Style="{StaticResource EditorTextBoxStyle}"/>

                                            <ComboBox Grid.Column="1"
                                      x:Name="JsvushfMinFreqUnitComboBox"
                                      Margin="4,0,0,0"
                                      Height="34"
                                      Background="#021522"
                                      Foreground="White"
                                      BorderBrush="#5A7388"
                                      SelectedIndex="0">
                                                <ComboBoxItem Content="MHz"/>
                                                <ComboBoxItem Content="GHz"/>
                                                <ComboBoxItem Content="KHz"/>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="MAX"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="70"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox x:Name="JsvushfMaxFreqTextBox"
                                     Text="1000"
                                     Style="{StaticResource EditorTextBoxStyle}"/>

                                            <ComboBox Grid.Column="1"
                                      x:Name="JsvushfMaxFreqUnitComboBox"
                                      Margin="4,0,0,0"
                                      Height="34"
                                      Background="#021522"
                                      Foreground="White"
                                      BorderBrush="#5A7388"
                                      SelectedIndex="0">
                                                <ComboBoxItem Content="MHz"/>
                                                <ComboBoxItem Content="GHz"/>
                                                <ComboBoxItem Content="KHz"/>
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>
                                </Grid>

                                <!-- SENSITIVITY / GAIN -->
                                <Grid Grid.Row="8" Margin="0,0,0,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="SENSITIVITY *"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Margin="0,0,0,2"/>
                                        <TextBlock Text="(-108 dBm to -30 dBm)"
                                   Foreground="White"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="40"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBox x:Name="JsvushfSensitivityTextBox"
                                     Text="-90"
                                     Style="{StaticResource EditorTextBoxStyle}"/>

                                            <TextBox Grid.Column="1"
                                     Text="dBm"
                                     Margin="4,0,0,0"
                                     Style="{StaticResource EditorTextBoxStyle}"/>
                                        </Grid>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="SETUP GAIN / LOSS *"
                                   Foreground="White"
                                   FontSize="12"
                                   FontWeight="Bold"
                                   Margin="0,0,0,2"/>
                                        <TextBlock Text="(-35 dB to 35 dB)"
                                   Foreground="White"
                                   FontSize="11"
                                   Margin="0,0,0,6"/>
                                        <Grid>
