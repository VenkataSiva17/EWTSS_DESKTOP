                                     Style="{StaticResource EditorTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="LONGITUDE"
                                       Foreground="White"
                                       FontSize="12"
                                       Margin="0,0,0,6"/>
