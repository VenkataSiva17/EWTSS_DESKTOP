<Page x:Class="EWTSS_DESKTOP.Presentation.Views.Scenario.ScenarioEditorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#021522"
      Title="ScenarioEditorPage">

    <Page.Resources>
        <Style x:Key="TopButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="30"/>
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Background" Value="#21B3AE"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="{x:Null}"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="FlatTreeItemStyle" TargetType="TreeViewItem">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#021522"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="#21B3AE"/>
                    <Setter Property="Background" Value="#021522"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Background" Value="#021522"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#5A7388"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="MiniMapButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="GridHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#21B3AE"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderBrush" Value="#021522"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <Style x:Key="GridCellStyle" TargetType="DataGridCell">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#032238"/>
            <Setter Property="BorderBrush" Value="#11364B"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <Style x:Key="GridRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="#032238"/>
            <Setter Property="Foreground" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0A3047"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#0A3047"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP HEADER -->
        <Grid Grid.Row="0" Background="#041B2B">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="4,0,0,0">
                <Button Width="28"
                        Height="28"
                        Margin="0,0,8,0"
                        Background="Transparent"
                        Foreground="White"
                        BorderBrush="#5A7388"
                        Click="Back_Click">
                    <TextBlock Text="←"
                               FontSize="15"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Image Source="C:\Users\Admin\Downloads\white.png"
                       Width="190"
                       Height="36"
                       Stretch="Uniform"
                       VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Column="1"
                       Text="Scenario Generator - EWTSS"
                       Foreground="White"
                       FontSize="17"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,12,0">
                <TextBlock x:Name="UserNameTextBlock"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0"/>
                <Ellipse Width="22"
                         Height="22"
                         Fill="#B9C37A"
                         VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- SECOND BAR -->
        <Grid Grid.Row="1" Background="#021522">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       x:Name="ScenarioTitleTextBlock"
                       Foreground="#21B3AE"
                       FontSize="13"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="70,0,0,0"/>

            <TextBlock Grid.Column="1"
                       Text="CONFIGURATION"
                       Foreground="White"
                       FontSize="13"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <StackPanel Grid.Column="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Margin="0,0,0,0">
                <Button Content="EXECUTE" Style="{StaticResource TopButtonStyle}"/>
                <Button Content="Start" Style="{StaticResource TopButtonStyle}"/>
                <Button Content="🟢 Start Recording"
                        Style="{StaticResource TopButtonStyle}"
                        MinWidth="120"/>
            </StackPanel>
        </Grid>

        <!-- MAIN CONTENT -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT TREE -->
            <Border Grid.Column="0"
                    Background="#021522"
                    BorderBrush="#30495C"
                    BorderThickness="0,1,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="44"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="SCENARIO"
                                   Foreground="#21B3AE"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Margin="12,12,0,8"/>

                        <TreeView x:Name="ScenarioTree"
                                  Margin="8,0,8,8"
                                  Background="#021522"
                                  Foreground="White"
                                  BorderBrush="{x:Null}"
                                  ItemContainerStyle="{StaticResource FlatTreeItemStyle}"/>
                    </StackPanel>

                    <Button Grid.Row="1"
                            Content="DRS DATA TABLE"
                            Width="120"
                            Height="30"
                            HorizontalAlignment="Left"
                            Margin="0,0,0,8"
                            Background="#21B3AE"
                            Foreground="White"
                            BorderBrush="{x:Null}"
                            FontWeight="Bold"/>
                </Grid>
            </Border>

            <!-- MIDDLE DETAILS -->
            <Grid Grid.Column="1" Background="#021522">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="230"/>
                </Grid.RowDefinitions>

                <!-- DETAILS PANEL -->
                <Border Grid.Row="0"
                        Background="#032238"
                        BorderBrush="#30495C"
                        BorderThickness="0,1,1,1"
                        Margin="0,0,0,10">
                    <Grid Margin="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="36"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="SCENARIO DETAILS"
                                   Style="{StaticResource PanelTitleStyle}"
                                   Margin="0,0,0,14"/>

                        <TextBlock Grid.Row="1"
                                   Text="SCENARIO NAME *"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,6"/>

                        <TextBox Grid.Row="2"
                                 x:Name="ScenarioNameTextBox"
                                 Style="{StaticResource EditorTextBoxStyle}"
                                 Margin="0,0,0,12"/>

                        <TextBlock Grid.Row="3"
                                   Text="DESCRIPTION"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,6"/>

                        <Grid Grid.Row="4" Margin="0,0,0,14">
                            <TextBox x:Name="ScenarioDescriptionTextBox"
                                     Height="78"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="#021522"
                                     Foreground="White"
                                     BorderBrush="#5A7388"
                                     BorderThickness="1"
                                     Padding="8"/>
                            <TextBlock x:Name="DescriptionCountTextBlock"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Margin="0,0,8,6"
                                       Foreground="#C9D4DD"
                                       FontSize="10"/>
                        </Grid>

                        <TextBlock Grid.Row="5"
                                   Text="SCENARIO SETTINGS"
                                   Style="{StaticResource PanelTitleStyle}"
                                   Margin="0,0,0,12"/>

                        <StackPanel Grid.Row="6" Margin="0,0,0,8">
                            <TextBlock x:Name="ScenarioCreatedDateTextBlock"
                                       Foreground="White"
                                       FontSize="12"
                                       Margin="0,0,0,5"/>
                            <TextBlock x:Name="ScenarioCreatedTimeTextBlock"
                                       Foreground="White"
                                       FontSize="12"/>
                        </StackPanel>

                        <TextBlock Grid.Row="7"
                                   Text="SCENARIO DURATION (HH:MM:SS) *"
                                   Style="{StaticResource LabelStyle}"
                                   Margin="0,0,0,6"/>

                        <Grid Grid.Row="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="34"/>
                                <RowDefinition Height="10"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="34"/>
                            </Grid.RowDefinitions>

                            <TextBox Grid.Row="0"
                                     x:Name="ScenarioDurationTextBox"
                                     Style="{StaticResource EditorTextBoxStyle}"/>

                            <TextBlock Grid.Row="2"
                                       Text="EXECUTION TIME (HH:MM:SS)"
                                       Style="{StaticResource LabelStyle}"
                                       Margin="0,0,0,6"/>

                            <TextBox Grid.Row="3"
                                     x:Name="ScenarioExecutionTimeTextBox"
                                     Style="{StaticResource EditorTextBoxStyle}"/>
                        </Grid>

                        <Button Grid.Row="9"
                                Content="UPDATE"
                                HorizontalAlignment="Right"
                                Width="80"
                                Background="Transparent"
                                Foreground="#21B3AE"
                                BorderBrush="{x:Null}"
                                FontWeight="Bold"
                                Click="UpdateScenario_Click"/>
                    </Grid>
                </Border>

                <!-- BOTTOM TABLE -->
                <Border Grid.Row="1"
                        Background="#032238"
                        BorderBrush="#30495C"
                        BorderThickness="0,1,1,0">
                    <DataGrid x:Name="DrsDataGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              Background="#032238"
                              Foreground="White"
                              RowBackground="#032238"
                              AlternatingRowBackground="#082D42"
                              ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                              CellStyle="{StaticResource GridCellStyle}"
                              RowStyle="{StaticResource GridRowStyle}"
                              Margin="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SNO" Binding="{Binding Sno}" Width="50"/>
                            <DataGridTextColumn Header="RED / BLUE" Binding="{Binding Side}" Width="70"/>
                            <DataGridTextColumn Header="EMITTER NAME" Binding="{Binding EmitterName}" Width="*"/>
                            <DataGridTextColumn Header="EMITTER TYPE" Binding="{Binding EmitterType}" Width="120"/>
                            <DataGridTextColumn Header="MODE" Binding="{Binding Mode}" Width="80"/>
                            <DataGridTextColumn Header="MODULATION" Binding="{Binding Modulation}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

            <!-- RIGHT VISUALIZATION -->
            <Grid Grid.Column="2" Background="Black">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#21B3AE">
                    <TextBlock Text="MAP VISUALIZATION"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <Grid Grid.Row="1" Background="Black">
                    <!-- left fake map toolbar -->
                    <StackPanel HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="12,12,0,0">
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="+"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="−"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="↔"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="⌖"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="◈"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="2D"/>
                    </StackPanel>

                    <!-- right fake map toolbar -->
                    <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0">
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="LoS"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="⊞"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="▤"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="Sy"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="🗓"/>
                    </StackPanel>

                    <!-- center placeholder -->
                    <TextBlock Text="3D VISUALIZATION"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <!-- top-right little menu -->
                    <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,40,12,0">
                        <Border Background="#168ED8" Padding="12,8">
                            <TextBlock Text="Create Viewshed" Foreground="White"/>
                        </Border>
                        <Border Background="#168ED8" Padding="12,8">
                            <TextBlock Text="Cancel" Foreground="White"/>
                        </Border>
                        <Border Background="#168ED8" Padding="12,8">
                            <TextBlock Text="Toggle Viewshed" Foreground="White"/>
                        </Border>
                    </StackPanel>

                    <!-- bottom right area info -->
                    <Border HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="0,0,12,10"
                            Background="#111111"
                            Padding="10,6">
                        <TextBlock Text="Total Area : 4.49 Kilometer Square"
                                   Foreground="White"
                                   FontSize="12"/>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Background="Black"
                        BorderBrush="#1C3242"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <TextBlock Text="SCENARIO PREVIEW :"
                                Foreground="White"
                                FontWeight="Bold"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="8,6,0,0"/>

                        <TextBlock Text="2D VISUALIZATION"
                                Foreground="White"
                                FontSize="16"
                                FontWeight="Bold"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                        <ComboBox Width="140"
                                Height="28"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                Margin="0,0,0,8"
                                Background="#021522"
                                Foreground="White"
                                BorderBrush="#5A7388">
                            <ComboBoxItem Content="DEGREE DECIMAL" IsSelected="True"/>
                        </ComboBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>