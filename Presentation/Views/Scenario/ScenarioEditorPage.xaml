                                            <ColumnDefinition Width="20"/>
                                            <ColumnDefinition Width="1*"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="ANTENNA TYPE *"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Margin="0,0,0,6"/>
