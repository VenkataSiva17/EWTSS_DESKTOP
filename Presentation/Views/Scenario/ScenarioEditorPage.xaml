                                 Text="1000"
                                 Style="{StaticResource EditorTextBoxStyle}"/>

                                        <ComboBox x:Name="RadarFrequencyUnitComboBox2"
                                  Grid.Column="1"
                                  Margin="4,0,0,0"
                                  Height="34"
                                  Background="#021522"
                                  Foreground="White"
                                  BorderBrush="#5A7388"
                                  SelectedIndex="0">
                                            <ComboBoxItem Content="MHz"/>
