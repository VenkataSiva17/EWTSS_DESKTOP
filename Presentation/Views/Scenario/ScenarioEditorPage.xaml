                                      Height="28"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Background="#021522"
                                      Foreground="White"
                                      BorderBrush="#5A7388">
                                <ComboBoxItem Content="DEGREE DECIMAL" IsSelected="True"/>
                            </ComboBox>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>