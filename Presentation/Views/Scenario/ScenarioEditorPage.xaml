                                        <ComboBoxItem Content="LAND STATIC" IsSelected="True"/>
                                        <ComboBoxItem Content="LAND MOBILE"/>
                                        <ComboBoxItem Content="AIR"/>
                                        <ComboBoxItem Content="SEA"/>
                                    </ComboBox>

                                    <TextBlock Text="POSITION"
                               Foreground="White"
                               FontSize="13"
                               FontWeight="Bold"
