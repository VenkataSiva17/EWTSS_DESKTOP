                                     Style="{StaticResource EditorTextBoxStyle}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="POLARIZATION"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Margin="0,0,0,6"/>
                                            <TextBox x:Name="RadarPolarizationTextBox2"
                                     Text="VERTICAL"
                                     Style="{StaticResource EditorTextBoxStyle}"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="SCAN RATE"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="Bold"
                               Margin="0,0,0,6"/>

                                    <TextBox x:Name="RadarScanRateTextBox2"
                             Text="0"
                             Style="{StaticResource EditorTextBoxStyle}"
                             Margin="0,0,0,20"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- TACTICAL TAB -->
                            <ScrollViewer x:Name="RadarTacticalScrollViewer2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
