                    Content="TECHNICAL"
                    Background="#2CB7B0"
                    Foreground="White"
                    BorderBrush="#5A7388"
                    FontSize="14"
                    FontWeight="Bold"
                    Click="RadarTechnicalTabButton2_Click"/>

                            <Button x:Name="RadarTacticalTabButton2"
                    Grid.Column="1"
                    Content="TACTICAL"
                    Background="#179C96"
                    Foreground="White"
                    BorderBrush="#5A7388"
                    FontSize="14"
                    FontWeight="Bold"
                    Click="RadarTacticalTabButton2_Click"/>
