                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Visible"/>

                    <TextBlock x:Name="Placeholder2DText"
                               Text="2D VISUALIZATION"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Visibility="Collapsed"/>

                    <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,40,12,0"
                                Panel.ZIndex="10">
                        <Border Background="#168ED8" Padding="12,8" Margin="0,0,0,6">
                            <TextBlock Text="Create Viewshed" Foreground="White"/>
                        </Border>
                        <Border Background="#168ED8" Padding="12,8" Margin="0,0,0,6">
                            <TextBlock Text="Cancel" Foreground="White"/>
                        </Border>
                        <Border Background="#168ED8" Padding="12,8">
                            <TextBlock Text="Toggle Viewshed" Foreground="White"/>
                        </Border>
                    </StackPanel>

                    <Border HorizontalAlignment="Stretch"
                            VerticalAlignment="Bottom"
                            Height="42"
                            Background="#0B0B0B"
                            BorderBrush="#1C3242"
                            BorderThickness="0,1,0,0"
                            Panel.ZIndex="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="170"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="SCENARIO PREVIEW :"
                                       Foreground="White"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="8,0,0,0"/>

                            <ComboBox Grid.Column="1"
