                               FontWeight="Bold"
                               Margin="0,0,0,6"/>
                                    <TextBox x:Name="RadarCallSignTextBox2"
                             Style="{StaticResource EditorTextBoxStyle}"
                             Margin="0,0,0,16"/>

                                    <TextBlock Text="EMITTER DURATION (HH:MM:SS)"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="Bold"
                               Margin="0,0,0,6"/>
                                    <TextBox x:Name="RadarDurationTextBox2"
                             Text="00:10:00"
                             Style="{StaticResource EditorTextBoxStyle}"
                             Margin="0,0,0,16"/>
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>

                        <Border Grid.Row="2" Background="#0C3144">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="90"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.Column="1"
                        Content="SAVE AS TEMPLATE"
                        Style="{StaticResource BottomActionButtonStyle}"
