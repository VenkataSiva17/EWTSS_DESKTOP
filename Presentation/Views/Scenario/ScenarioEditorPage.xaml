                        Content="ADD"
                        Style="{StaticResource BottomActionButtonStyle}"
                        Foreground="#21B3AE"
                        Click="CreateRadar_Click"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>







                <!-- BOTTOM TABLE -->
                <Border x:Name="DrsTableBorder"
                        Grid.Row="1"
                        Background="#032238"
                        BorderBrush="#30495C"
                        BorderThickness="0,1,1,0">
                    <DataGrid x:Name="DrsDataGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="None"
                              BorderThickness="0"
                              Background="#032238"
                              Foreground="White"
                              RowBackground="#032238"
                              AlternatingRowBackground="#082D42"
                              ColumnHeaderStyle="{StaticResource GridHeaderStyle}"
                              CellStyle="{StaticResource GridCellStyle}"
                              RowStyle="{StaticResource GridRowStyle}"
                              Margin="0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="SNO" Binding="{Binding Sno}" Width="50"/>
                            <DataGridTextColumn Header="RED / BLUE" Binding="{Binding Side}" Width="70"/>
                            <DataGridTextColumn Header="EMITTER NAME" Binding="{Binding EmitterName}" Width="*"/>
                            <DataGridTextColumn Header="EMITTER TYPE" Binding="{Binding EmitterType}" Width="120"/>
                            <DataGridTextColumn Header="MODE" Binding="{Binding Mode}" Width="80"/>
                            <DataGridTextColumn Header="MODULATION" Binding="{Binding Modulation}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </Grid>

          <!-- RIGHT VISUALIZATION -->
            <Grid Grid.Column="2" Background="Black">
                <Grid.RowDefinitions>
                    <RowDefinition Height="36"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#21B3AE">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="MAP VISUALIZATION"
                               Foreground="White"
                               FontSize="14"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <Button Grid.Column="1"
                            x:Name="Btn3D"
