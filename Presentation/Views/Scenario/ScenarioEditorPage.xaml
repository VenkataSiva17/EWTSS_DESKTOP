                            Click="Btn3D_Click"/>

                    <Button Grid.Column="2"
                            x:Name="Btn2D"
                            Content="2D"
                            Margin="5,3,10,3"
                            Background="Transparent"
                            Foreground="White"
                            BorderBrush="{x:Null}"
                            FontWeight="Bold"
                            Click="Btn2D_Click"/>
                </Grid>

                <Grid Grid.Row="1" Background="Black">
                    <StackPanel HorizontalAlignment="Left"
                                VerticalAlignment="Top"
                                Margin="12,12,0,0"
                                Panel.ZIndex="10">
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="+"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="−"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="↔"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="⌖"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="◈"/>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,12,0"
                                Panel.ZIndex="10">
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="LoS"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="⊞"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="▤"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="Sy"/>
                        <Button Style="{StaticResource MiniMapButtonStyle}" Content="🗓"/>
                    </StackPanel>

                    <wf:WindowsFormsHost x:Name="Host3D" Visibility="Visible"/>
                    <wf:WindowsFormsHost x:Name="Host2D" Visibility="Collapsed"/>

                    <TextBlock x:Name="Placeholder3DText"
