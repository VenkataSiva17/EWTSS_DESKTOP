                                     Style="{StaticResource EditorTextBoxStyle}"/>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Text="EMITTER TYPE *"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="Bold"
                               Margin="0,0,0,6"/>

