                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBox x:Name="RadarGainTextBox2"
                                         Text="0"
                                         Style="{StaticResource EditorTextBoxStyle}"/>

                                                <TextBox Grid.Column="1"
                                         Text="dB"
                                         Margin="4,0,0,0"
                                         Style="{StaticResource EditorTextBoxStyle}"/>
                                            </Grid>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="POWER TRANSMITTED *"
                                       Foreground="White"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Margin="0,0,0,6"/>
