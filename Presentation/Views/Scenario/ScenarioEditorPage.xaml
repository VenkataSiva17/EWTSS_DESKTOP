                               Foreground="White"
                               FontSize="12"
                               Margin="0,0,0,6"/>

                                    <ComboBox x:Name="RadarTemplateComboBox2"
                             Style="{StaticResource DarkComboBoxStyle}"
ItemContainerStyle="{StaticResource DarkComboBoxItemStyle}"
 SelectedIndex="0"
  Margin="0,0,0,16">
                                        <ComboBoxItem Content="SELECT TEMPLATE" IsSelected="True"/>
                                    </ComboBox>

                                    <TextBlock Text="RADAR NAME *"
                               Foreground="White"
                               FontSize="12"
                               FontWeight="Bold"
                               Margin="0,0,0,6"/>

